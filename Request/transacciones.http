@api = http://localhost:3700

### ─── RETIRO directo en USD (tiene saldo USD) ───────────────
# Retira 1 USD directamente desde saldo en USD.
# confirmar_conversion no aplica aquí (hay saldo directo).
POST {{api}}/retiro
Content-Type: application/json

{
  "numero_tarjeta": "4851617793844965",
  "pin": "5903",
  "monto": 1,
  "moneda": "USD",
  "moneda_salida": "USD",
  "tipo_tasa": "binance",
  "metodo": "ATM"
}

### ─── RETIRO BOB directo ────────────────────────────────────
# Retira 500 BOB directamente desde saldo en BOB.
POST {{api}}/retiro
Content-Type: application/json

{
  "numero_tarjeta": "4851617793844965",
  "pin": "5903",
  "monto": 500,
  "moneda": "BOB",
  "moneda_salida": "BOB",
  "tipo_tasa": "oficial",
  "metodo": "ATM"
}

### ─── RETIRO con conversión (BOB → USD, confirmar) ─────────
# No tiene saldo en USD → descuenta BOB equivalentes.
# Paso 1: enviar sin confirmar_conversion para ver cuánto BOB se usará.
# Paso 2: reenviar con confirmar_conversion: true para ejecutar.
POST {{api}}/retiro
Content-Type: application/json

{
  "numero_tarjeta": "4851617793844965",
  "pin": "5903",
  "monto": 10,
  "moneda": "PEN",
  "moneda_salida": "PEN",
  "tipo_tasa": "binance",
  "metodo": "ATM",
  "confirmar_conversion": true
}

### ─── DEPÓSITO directo BOB ──────────────────────────────────
# Deposita 500 BOB → acredita 500 BOB. Sin conversión.
POST {{api}}/deposito
Content-Type: application/json

{
  "correo": "jazielarmandovargaschoque@gmail.com",
  "numero_tarjeta": "4851617793844965",
  "contrasena": "DrXeno79TESLA",
  "pin": "5903",
  "monto": 500,
  "moneda_origen": "BOB",
  "moneda_destino": "BOB",
  "tipo_tasa": "binance",
  "metodo": "ATM"
}

### ─── DEPÓSITO multimoneda USD → BOB ───────────────────────
# Deposita 100 USD → acredita el equivalente en BOB según tasa binance.
POST {{api}}/deposito
Content-Type: application/json

{
  "correo": "jazielarmandovargaschoque@gmail.com",
  "numero_tarjeta": "4851617793844965",
  "contrasena": "DrXeno79TESLA",
  "pin": "5903",
  "monto": 100,
  "moneda_origen": "USD",
  "moneda_destino": "BOB",
  "tipo_tasa": "binance",
  "metodo": "web"
}

### ─── DEPÓSITO multimoneda BOB → USD ───────────────────────
# Deposita 100 BOB → acredita el equivalente en USD según tasa binance.
POST {{api}}/deposito
Content-Type: application/json

{
  "correo": "jazielarmandovargaschoque@gmail.com",
  "numero_tarjeta": "4851617793844965",
  "contrasena": "DrXeno79TESLA",
  "pin": "5903",
  "monto": 100,
  "moneda_origen": "BOB",
  "moneda_destino": "USD",
  "tipo_tasa": "binance",
  "metodo": "web"
}

### ─── TRANSFERENCIA directa BOB → BOB ──────────────────────
# Transfiere 200 BOB sin conversión.
POST {{api}}/transferencia
Content-Type: application/json

{
  "numero_de_cuenta": "5851617743407592",
  "numero_cuenta_destino": "5704213255142001",
  "monto": 200,
  "moneda_origen": "BOB",
  "moneda_destino": "BOB",
  "tipo_tasa": "oficial",
  "metodo": "ATM",
  "descripcion": "Pago de deuda"
}

### ─── TRANSFERENCIA multimoneda BOB → USD (paso 1: consultar) ──
# Devuelve 202 con el detalle de conversión. No ejecuta aún.
POST {{api}}/transferencia
Content-Type: application/json

{
  "numero_de_cuenta": "5851617743407592",
  "numero_cuenta_destino": "5704213255142001",
  "monto": 100,
  "moneda_origen": "BOB",
  "moneda_destino": "USD",
  "tipo_tasa": "oficial",
  "metodo": "web",
  "descripcion": "Transferencia internacional",
  "confirmar_conversion": true
}

### ─── TRANSFERENCIA multimoneda BOB → USD (paso 2: confirmar) ──
# Mismo request anterior pero con confirmar_conversion: true para ejecutar.
POST {{api}}/transferencia
Content-Type: application/json

{
  "numero_de_cuenta": "5851617743407592",
  "numero_cuenta_destino": "5704213255142001",
  "monto": 100,
  "moneda_origen": "BOB",
  "moneda_destino": "USD",
  "tipo_tasa": "oficial",
  "metodo": "web",
  "descripcion": "Transferencia internacional",
  "confirmar_conversion": true
}

### ─── TRANSFERENCIA directa USD → USD ──────────────────────
# Transfiere 13 USD sin conversión (ambas cuentas en USD).
POST {{api}}/transferencia
Content-Type: application/json

{
  "numero_de_cuenta": "5851617743407592",
  "numero_cuenta_destino": "5704213255142001",
  "monto": 13,
  "moneda_origen": "USD",
  "moneda_destino": "USD",
  "tipo_tasa": "binance",
  "metodo": "ATM",
  "descripcion": "Pago en dólares"
}

